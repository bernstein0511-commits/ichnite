{
  "manifest_version": 3,
  "name": "Ichnite",
  "version": "1.0.0",
  "description": "読解の足跡を残すマーカーツール",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "action": {
    "default_popup": "ui/popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],

      "js": [
        "content/content.js",
        "modules/storage.js",
        "modules/popup.js",
        "modules/restore.js",
        "modules/marker.js",
        "modules/panel.js"
      ],

      "css": [
        "content/content.css"
      ]
    }
  ]
}